# Ignore node_modules and build artifacts
**/node_modules/
**/dist/
**/build/
**/.next/
**/out/

# Ignore Python virtual environments
**/venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/

# Ignore Git
**/.git/

# Ignore build outputs
**/coverage/
**/.turbo/
**/.vercel/

# Ignore large directories
frontend/web/node_modules/
frontend/mobile/node_modules/
firebase/functions/node_modules/
firebase/public/
backend/venv/

# Ignore backups
antigravity-backup-*/
backup-*/
*_test_output/

# Ignore databases
*.sqlite3
*.sqlite3-journal
*.sqlite3.backup-*
db.sqlite3

# Ignore environment files
**/.env
**/.env.*
**/serviceAccountKey.json
**/*.secret
**/credentials*.json

# Ignore IDE files
**/.idea/
**/.vscode/
**/*.swp
**/*.swo

# Ignore logs
**/*.log
**/logs/

# Ignore OS files
**/.DS_Store
**/Thumbs.db

# Ignore large generated files
**/*.min.js
**/*.map
**/*.bundle.js
